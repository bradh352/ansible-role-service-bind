$TTL 600
@   IN  SOA {{ inventory_hostname }}. no.monitored.email. (
       {{ now(fmt="%y%m%d%H%M") }} ; Serial
       3600       ; Refresh
       1800       ; Retry
       1209600    ; Expire
       86400 )    ; Minimum TTL

{% if bind_group is defined %}
{%   for host in groups[bind_group] | sort %}
   IN  NS  {{ host }}.
{%   endfor %}
{% else %}
   IN  NS  {{ inventory_hostname }}.
{% endif %}

