{% if bind_group is defined %}
{%   set ns = namespace(primary_ip=None, primary_host=None, secondary_ips=[]) %}
{%   for host in groups[bind_group] %}
{%     if hostvars[host].bind_primary is defined %}
{%       set ns.primary_ip = hostvars[host].bind_ip %}
{%       set ns.primary_host = host %}
{%     else %}
{%       do ns.secondary_ips.append(hostvars[host].bind_ip) %}
{%     endif %}
{%   endfor %}
{% endif %}
options {
	listen-on port 53 { any; };
	listen-on-v6 port 53 { any; };
	directory          "{{ bind_path }}";
	dump-file          "{{ bind_data_path }}/cache_dump.db";
	statistics-file    "{{ bind_data_path }}/named_stats.txt";
	memstatistics-file "{{ bind_data_path }}/named_mem_stats.txt";
	secroots-file      "{{ bind_data_path }}/named.secroots";
	recursing-file     "{{ bind_data_path }}/named.recursing";
	allow-query        { any; };

	recursion {{ 'yes' if bind_recursive|default(true) else 'no' }};

	dnssec-validation yes;

	managed-keys-directory "{{ bind_dynamic_path }}";

	pid-file "/run/named/named.pid";
	session-keyfile "/run/named/session.key";

{% if ansible_os_family == 'RedHat' %}
	/* https://fedoraproject.org/wiki/Changes/CryptoPolicy */
	include "/etc/crypto-policies/back-ends/bind.config";
{% endif %}
};

logging {
	channel default_syslog {
		print-time yes;
		print-category yes;
		print-severity yes;
		syslog daemon;
		severity info;
	};
};

zone "." IN {
	type hint;
	file "named.ca";
};

include "/etc/named.rfc1912.zones";
include "/etc/named.root.key";

{% for forward in bind_forward %}
zone "{{ forward.domain }}" {
	type forward;
	forward only;
	forwarders { {{ forward.servers | join("; ") }}; };
};

{% endfor %}
{% for key in bind_keys %}
key "{{ key.name }}" {
	algorithm {{ key.algorithm|default('hmac-sha256') }};
	secret "{{ key.secret }}";
};

{% endfor %}
{% for zone in bind_zones %}
zone "{{ zone.domain }}" IN {
{%   if zone.dynamic_key is defined %}
{%     if bind_group is not defined or ns.primary_host == inventory_hostname %}
	type primary;
	file "{{ bind_dynamic_path }}/{{ zone.domain }}.zone";
	allow-update { key {{ zone.dynamic_key }}; };
{%       if bind_group is defined %}
	allow-transfer { {{ ns.secondary_ips|sort|join(';') }}; };
	also-notify { {{ ns.secondary_ips|sort|join(';') }}; };
{%       endif %}
{%     else %}
	type secondary;
	file "{{ bind_dynamic_path }}/{{ zone.domain }}.zone";
	primaries { {{ ns.primary_ip }}; };
	allow-notify { {{ ns.primary_ip }}; };
{%     endif %}
{%   else %}
	type primary;
	file "{{ bind_zone_path }}/{{ zone.domain }}.zone";
{%   endif %}
};
{% endfor %}
{% for prefix, zone in reverse_zones.items() %}
{%   set type='in-addr.arpa' if prefix|split(".")|length < 4 else 'ip6.arpa' %}
zone "{{ prefix }}.{{ type }}" IN {
	type master;
	file "{{ prefix }}.{{ type }}.zone";
};
{% endfor %}
